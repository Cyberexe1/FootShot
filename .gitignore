# =========================================================================
# Allowlist: only the application code is pushed to GitHub.
# Everything at the repo root is ignored by default, then the app folders
# (frontend + backend) and a couple of essentials are re-included.
# Excluded on purpose: infra/, loadtest/, planning & ops docs (*.md),
# deploy scripts and token files.
# =========================================================================
/*

!/frontend/
!/backend/
!/.github/
!/README.md
!/.gitignore

# ------------------------------------------------------------------------
# Within the tracked folders, never commit these.
# ------------------------------------------------------------------------
node_modules/
dist/
build/
coverage/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Env & secrets (keep the examples)
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
