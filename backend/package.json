{
  "name": "fanflow26-backend",
  "version": "0.1.0",
  "private": true,
  "description": "FanFlow 26 backend API — Node.js + Express + TypeScript",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "3.658.1",
    "@aws-sdk/client-dynamodb": "3.658.1",
    "@aws-sdk/lib-dynamodb": "3.658.1",
    "cors": "2.8.5",
    "express": "4.21.0",
    "express-rate-limit": "7.4.0",
    "helmet": "7.1.0",
    "pino": "9.4.0",
    "pino-http": "10.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.16.10",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "8.8.0",
    "@typescript-eslint/parser": "8.8.0",
    "eslint": "8.57.1",
    "supertest": "7.0.0",
    "tsx": "4.19.1",
    "typescript": "^5.5.4",
    "vitest": "2.1.1"
  }
}
