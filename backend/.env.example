# Copy to .env for local development. Do NOT commit real values.
NODE_ENV=development
PORT=8080

# Comma-separated allowed CORS origins. Use the CloudFront domain in production.
CORS_ORIGINS=http://localhost:5173

# AWS
AWS_REGION=us-east-1

# Amazon Bedrock (Amazon Nova). Ensure the model is enabled in this region and
# that the runtime has bedrock:InvokeModel / InvokeModelWithResponseStream.
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=1024
BEDROCK_TEMPERATURE=0.3

# Auth: JWT signing secret + operator credentials.
# Passwords are stored as bcrypt hashes; generate with:
#   node -e "console.log(require('bcryptjs').hashSync('yourpassword',10))"
AUTH_JWT_SECRET=dev-insecure-jwt-secret-change-me
AUTH_JWT_EXPIRES_IN=8h
STAFF_USERNAME=operator
ORGANIZER_USERNAME=organizer
# Set these in production (bcrypt hashes). If unset, the plaintext fallbacks
# below are hashed at startup (dev only).
# STAFF_PASSWORD_HASH=
# ORGANIZER_PASSWORD_HASH=
STAFF_PASSWORD=operator123
ORGANIZER_PASSWORD=organizer123

# Incidents storage. If unset, an in-memory store is used (demo only).
# INCIDENTS_TABLE=fanflow26-incidents

# Logging
LOG_LEVEL=info
